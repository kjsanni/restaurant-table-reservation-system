{
  "name": "restaurant-table-reservation-system-front-end",
  "version": "1.0.0",
  "description": "Front-end of Restaurant Table Reservation System. Created with VueJS 3.",
  "repository": {
    "type": "git",
    "url": "https://github.com/slavyanHristov/restaurant-table-reservation-system",
    "directory": "/front-end"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postinstall": "bash scripts/patch-vuestic-useTeleported.sh",
    "build:analyze": "vite build && open dist/stats.html",
    "preview": "vite preview",
    "test:unit": "vitest run --environment jsdom",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "format": "prettier .  --write",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@iconify/json": "^2.1.131",
    "@iconify/vue": "^4.3.0",
    "@vue/compiler-sfc": "^3.2.41",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.1.3",
    "date-fns": "^4.4.0",
    "pinia": "^3.0.4",
    "socket.io-client": "^4.8.3",
    "unplugin-icons": "^0.14.12",
    "vue": "^3.4.21",
    "vue-router": "^4.1.5"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.1.4",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitejs/plugin-vue": "^3.1.2",
    "@vue/eslint-config-prettier": "^7.0.0",
    "@vue/eslint-config-typescript": "^9.1.0",
    "@vue/test-utils": "^2.1.0",
    "eslint": "^8.22.0",
    "eslint-plugin-vue": "^9.3.0",
    "jsdom": "^20.0.1",
    "prettier": "^2.7.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^6.0.3",
    "vite": "^3.1.8",
    "vitest": "^0.24.3",
    "vuestic-ui": "^1.10.3"
  }
}
