{
  "name": "restaurant-table-reservation-system-front-end",
  "version": "1.0.0",
  "description": "Front-end of Restaurant Table Reservation System. Created with VueJS 3.",
  "repository": {
    "type": "git",
    "url": "https://github.com/slavyanHristov/restaurant-table-reservation-system",
    "directory": "/front-end"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:unit": "vitest --environment jsdom --root src/",
    "test:a11y": "playwright test tests/accessibility.spec.ts",
    "test:visual": "playwright test tests/visual.spec.ts",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "format": "prettier .  --write"
  },
  "dependencies": {
    "@iconify/json": "^2.1.131",
    "@iconify/utils": "2.2.0",
    "@iconify/vue": "^4.0.0",
    "@vue/compiler-sfc": "^3.2.41",
    "axios": "^1.1.3",
    "chart.js": "^4.5.1",
    "pinia": "^3.0.4",
    "socket.io-client": "^4.8.3",
    "unplugin-icons": "^0.14.12",
    "vue": "^3.5.39",
    "vue-router": "^4.1.5",
    "vuestic-ui": "^1.10.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@rushstack/eslint-patch": "^1.1.4",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/eslint-config-prettier": "^7.0.0",
    "@vue/test-utils": "^2.1.0",
    "eslint": "^8.22.0",
    "eslint-plugin-vue": "^9.3.0",
    "jsdom": "^20.0.1",
    "playwright": "^1.61.1",
    "prettier": "^2.7.1",
    "rollup": "^4.62.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "rollup-plugin-vue": "^6.0.0",
    "typescript": "^5.4.5",
    "vite": "^6.4.3",
    "vitest": "^3.2.7",
    "vue-tsc": "^2.2.12"
  }
}
