{
  "name": "rtr-staff-app",
  "version": "0.1.0",
  "private": true,
  "description": "React Native staff app for the Restaurant Table Reservation System — floor management with real-time Socket.IO updates.",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
