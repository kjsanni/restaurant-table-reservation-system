{
  "expo": {
    "name": "RTRS Staff",
    "slug": "rtr-staff-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#faf6f3",
      "resizeMode": "contain",
      "image": "./assets/splash.png"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "tech.vibespot.rtr-staff"
    },
    "android": {
      "package": "tech.vibespot.rtr_staff",
      "adaptiveIcon": {
        "backgroundColor": "#8c5e4a"
      }
    },
    "extra": {
      "API_BASE_URL": "http://localhost:8000/api/v1",
      "SOCKET_URL": "http://localhost:8000"
    }
  }
}
