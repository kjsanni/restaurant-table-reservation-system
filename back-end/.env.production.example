# Production Environment Configuration
# Copy to .env in back-end directory and fill in values

# JWT Secret (REQUIRED - generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_GENERATE_A_SECURE_SECRET

# JWT Expiry (recommended: 15-30 minutes)
JWT_EXPIRES_IN=30m

# Refresh Token Expiry
REFRESH_TOKEN_EXPIRES_IN=30d

# Database Configuration
DB_HOST=127.0.0.1
DB_USERNAME=rtrs_user
DB_PASSWORD=secure-password
DB_NAME=rtrs_production
DB_DIALECT=mysql
DB_PORT=3306

# Read Replica Configuration (optional)
# Leave DB_HOST_REPLICA empty to run against a single database (default).
# When DB_HOST_REPLICA is set, read-heavy reporting/analytics SELECT queries are
# routed to the replica automatically (Sequelize read/write splitting), with
# automatic fallback to the primary if the replica is unreachable.
# See Specs/read-replica-integration.md for details.
DB_HOST_REPLICA=
DB_PORT_REPLICA=3306
# Credentials fall back to the primary DB_USERNAME/DB_PASSWORD when omitted.
DB_USERNAME_REPLICA=
DB_PASSWORD_REPLICA=
# Kill switch: set to "false" to disable replica routing without removing config.
DB_REPLICA_ENABLED=true
# Optional replica-specific connection pool sizing (falls back to primary pool).
DB_POOL_MIN_REPLICA=2
DB_POOL_MAX_REPLICA=20
DB_POOL_IDLE_REPLICA=10000
DB_POOL_ACQUIRE_REPLICA=30000

# Database connection pool (primary)
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_IDLE=10000
DB_POOL_ACQUIRE=30000

# Rate limiting overrides (optional). Leave empty to use built-in defaults.
# RATE_LIMIT_AUTH_MAX=10
# RATE_LIMIT_GENERAL_MAX=100
# RATE_LIMIT_BULK_MAX=5
# RATE_LIMIT_ADMIN_MAX=3
# RATE_LIMIT_SYNC_MAX=60
# RATE_LIMIT_WEBHOOK_MAX=120
# RATE_LIMIT_DISABLED=false

# Server Configuration
PORT=8000
NODE_ENV=production

# CORS Origins (comma-separated)
# These should exactly match the browser Origin header (scheme + host + port).
# For IP-based access without HTTPS:
#   CORS_ORIGINS=http://192.168.88.10,http://192.168.88.10:8080
# For domain-based access with HTTPS:
#   CORS_ORIGINS=https://restaurant.example.com,https://admin.example.com
CORS_ORIGINS=https://your-domain.com

# Frontend and API URLs for CSP and cookie handling
FRONTEND_URL=http://192.168.88.10
API_URL=http://192.168.88.10

# Redis Configuration (for caching) - Leave empty to disable
REDIS_HOST=localhost
REDIS_PORT=6379

# Sentry Error Tracking (optional)
# Get your DSN from https://sentry.io after creating a project
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0000000

# Log Level
LOG_LEVEL=error

# SSL/TLS Configuration (production only)
# Set to 'true' to enable HTTPS in production
SSL_ENABLED=true
# Path to SSL certificate file (absolute path recommended)
SSL_CERT_PATH=/etc/ssl/certs/restaurant-table-reservation.crt
# Path to SSL private key file
SSL_KEY_PATH=/etc/ssl/private/restaurant-table-reservation.key

# Public base URL (used to build Paystack/webhook callback URLs)
APP_URL=https://your-domain.com

# WhatsApp Business API (can also be configured in Admin Settings > Integrations)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Paystack payments (can also be configured in Admin Settings > Integrations)
PAYSTACK_MODE=live
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

# Multi-Tenant SaaS module (set to "enabled" to load tenant routes/middleware)
TENANT_MODE=disabled
